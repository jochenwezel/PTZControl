<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PTZControl2.CameraInfoDialog"
        Title="Camera info"
        Width="620"
        Height="420"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="Manual">
  <Grid Margin="16" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
    <StackPanel Orientation="Horizontal" Spacing="12">
      <TextBlock Text="Camera monitor"
                 FontSize="20"
                 FontWeight="SemiBold" />
      <TextBlock x:Name="RefreshStatusText"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource AppMutedTextBrush}" />
    </StackPanel>
    <TextBlock Grid.Row="1"
               Text="Read-only refresh every second. Current values are useful for checking driver state while using live controls."
               Foreground="{DynamicResource AppMutedTextBrush}"
               TextWrapping="Wrap" />
    <TextBox x:Name="InfoText"
             Grid.Row="2"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             FontFamily="Consolas" />
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Content="Refresh now"
              MinWidth="110"
              Click="RefreshNowButton_Click" />
      <Button Content="Close"
              MinWidth="90"
              Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
