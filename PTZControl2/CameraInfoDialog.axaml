<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PTZControl2.CameraInfoDialog"
        Title="Camera info"
        Width="620"
        Height="420"
        MinWidth="480"
        MinHeight="320"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
    <TextBlock Text="Camera information"
               FontSize="20"
               FontWeight="SemiBold" />
    <TextBox x:Name="InfoText"
             Grid.Row="1"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             FontFamily="Consolas" />
    <Button Grid.Row="2"
            Content="Close"
            HorizontalAlignment="Right"
            MinWidth="90"
            Click="CloseButton_Click" />
  </Grid>
</Window>
