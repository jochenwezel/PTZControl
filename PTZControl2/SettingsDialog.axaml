<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PTZControl2.SettingsDialog"
        Title="PTZControl2 Settings"
        Width="700"
        Height="520"
        MinWidth="700"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        KeyDown="Window_KeyDown">
  <Window.Styles>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.hint">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Button.dialogAction">
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.warningBox">
      <Setter Property="Background" Value="{DynamicResource AppWarningStatusBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppWarningStatusBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="10" />
    </Style>
  </Window.Styles>

  <Grid Margin="20" RowDefinitions="*,Auto" RowSpacing="16">
    <TabControl>
      <TabItem Header="Camera">
        <ScrollViewer Margin="4,16">
          <StackPanel Spacing="12" Margin="0,0,18,0">
            <TextBlock Text="Camera names" Classes="sectionTitle" />
            <TextBlock x:Name="CameraNameLabelTextBlock"
                       Classes="hint" />
            <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
              <TextBlock Text="Camera slot name"
                         VerticalAlignment="Center" />
              <TextBox x:Name="CameraSlotNameTextBox"
                       Grid.Column="1" />
              <TextBlock Grid.Row="1"
                         Text="Device display name"
                         VerticalAlignment="Center" />
              <TextBox x:Name="DeviceDisplayNameTextBox"
                       Grid.Row="1"
                       Grid.Column="1" />
            </Grid>
            <Border Classes="warningBox">
              <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                <TextBlock Text="⚠"
                           FontSize="18"
                           VerticalAlignment="Top" />
                <TextBlock Grid.Column="1"
                           Text="Changing the device display name is a system-wide, persistent Windows device rename and may require administrator approval."
                           TextWrapping="Wrap" />
              </Grid>
            </Border>
            <StackPanel x:Name="CameraOptionsPanel" Spacing="12" Margin="0,12,0,0">
              <TextBlock Text="Global camera options" Classes="sectionTitle" />
              <TextBlock Classes="hint"
                         Text="These settings apply to the whole PTZControl2 camera list and preview behavior, not only to the selected camera slot." />
              <TextBlock Text="Camera list" Classes="sectionTitle" Margin="0,8,0,0" />
              <CheckBox x:Name="ShowOnlyLogitechCamerasCheckBox"
                        Content="Show only Logitech USB cameras" />
              <TextBlock Classes="hint"
                         Text="This Windows-only filter uses the USB vendor ID in the device path. Slot numbers stay unchanged." />
              <TextBlock Text="Live preview" Classes="sectionTitle" Margin="0,12,0,0" />
              <CheckBox x:Name="PreviewTopMostCheckBox"
                        Content="Keep live preview on top" />
              <TextBlock Classes="hint"
                         Text="When disabled, the preview window stays independent while PTZControl2 remains the primary control surface." />
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Movement">
        <StackPanel Margin="4,16" Spacing="12">
          <TextBlock Text="Camera movement" Classes="sectionTitle" />
          <TextBlock x:Name="CameraLabelTextBlock"
                     Classes="hint" />
          <CheckBox x:Name="InvertPanCheckBox"
                    Content="Invert pan actions" />
          <CheckBox x:Name="InvertTiltCheckBox"
                    Content="Invert tilt actions" />
          <TextBlock Classes="hint"
                     Text="Use pan/tilt inversion when the camera is mounted upside down or the desired operator direction differs from the device direction." />
        </StackPanel>
      </TabItem>

      <TabItem Header="Presets">
        <ScrollViewer Margin="4,16">
          <StackPanel Spacing="10" Margin="0,0,18,0">
            <TextBlock Text="Preset names" Classes="sectionTitle" />
            <TextBlock x:Name="PresetCameraLabelTextBlock"
                       Classes="hint" />
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="12" RowSpacing="8">
              <TextBlock Text="Preset 1" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName1TextBox" Grid.Column="1" />
              <TextBlock Grid.Row="1" Text="Preset 2" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName2TextBox" Grid.Row="1" Grid.Column="1" />
              <TextBlock Grid.Row="2" Text="Preset 3" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName3TextBox" Grid.Row="2" Grid.Column="1" />
              <TextBlock Grid.Row="3" Text="Preset 4" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName4TextBox" Grid.Row="3" Grid.Column="1" />
              <TextBlock Grid.Row="4" Text="Preset 5" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName5TextBox" Grid.Row="4" Grid.Column="1" />
              <TextBlock Grid.Row="5" Text="Preset 6" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName6TextBox" Grid.Row="5" Grid.Column="1" />
              <TextBlock Grid.Row="6" Text="Preset 7" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName7TextBox" Grid.Row="6" Grid.Column="1" />
              <TextBlock Grid.Row="7" Text="Preset 8" VerticalAlignment="Center" />
              <TextBox x:Name="PresetName8TextBox" Grid.Row="7" Grid.Column="1" />
            </Grid>
          </StackPanel>
        </ScrollViewer>
      </TabItem>

      <TabItem Header="Compatibility">
        <StackPanel Margin="4,16" Spacing="14">
          <TextBlock Text="Compatibility options" Classes="sectionTitle" />
          <TextBlock x:Name="CompatibilityCameraLabelTextBlock"
                     Classes="hint" />
          <StackPanel Spacing="8">
            <TextBlock Text="Movement control backend" />
            <RadioButton x:Name="StandardUvcControlRadioButton"
                         GroupName="MovementControlBackend"
                         Content="Standard UVC controls" />
            <TextBlock Classes="hint"
                       Margin="24,-6,0,0"
                       Text="Use regular Windows camera driver controls for pan, tilt, and zoom. This is the preferred default when the camera exposes these controls correctly." />
            <RadioButton x:Name="LogitechControlRadioButton"
                         GroupName="MovementControlBackend"
                         Content="Logitech extension controls" />
            <TextBlock Classes="hint"
                       Margin="24,-6,0,0"
                       Text="Use the original PTZControl Logitech peripheral control extension path for compatible Logitech PTZ cameras." />
          </StackPanel>
          <Grid ColumnDefinitions="Auto,120,Auto" ColumnSpacing="10">
            <TextBlock Text="Motor time"
                       VerticalAlignment="Center" />
            <TextBox x:Name="MotorTimeTextBox"
                     Grid.Column="1"
                     HorizontalContentAlignment="Center" />
            <TextBlock Grid.Column="2"
                       Text="msec"
                       VerticalAlignment="Center" />
          </Grid>
          <TextBlock Classes="hint"
                     Text="These values are compatible with the original PTZControl settings." />
        </StackPanel>
      </TabItem>

      <TabItem Header="Appearance">
        <StackPanel Margin="4,16" Spacing="12">
          <TextBlock Text="Appearance" Classes="sectionTitle" />
          <ComboBox x:Name="ThemeModeComboBox"
                    Width="180"
                    HorizontalAlignment="Left">
            <ComboBoxItem Content="System" />
            <ComboBoxItem Content="Light" />
            <ComboBoxItem Content="Dark" />
          </ComboBox>
          <TextBlock Classes="hint"
                     Text="System follows the operating system theme. Light and Dark override it for PTZControl2." />
        </StackPanel>
      </TabItem>

    </TabControl>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8">
      <Button Classes="dialogAction"
              Content="Cancel"
              Click="CancelButton_Click" />
      <Button Classes="dialogAction"
              Content="Save"
              Click="SaveButton_Click" />
    </StackPanel>
  </Grid>
</Window>
