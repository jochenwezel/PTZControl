<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PTZControl2.AboutDialog"
        Title="About PTZControl2"
        Width="560"
        Height="440"
        MinWidth="520"
        MinHeight="400"
        WindowStartupLocation="Manual"
        KeyDown="Window_KeyDown">
  <Window.Styles>
    <Style Selector="TextBlock.title">
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>
    <Style Selector="TextBlock.hint">
      <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Button.dialogAction">
      <Setter Property="MinWidth" Value="92" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Grid Margin="20" RowDefinitions="*,Auto" RowSpacing="16">
    <TabControl>
      <TabItem Header="About">
        <StackPanel Margin="4,16" Spacing="14">
          <StackPanel Spacing="4">
            <TextBlock Text="PTZControl2" Classes="title" />
            <TextBlock Text="Modern PTZControl graphical application." Classes="hint" />
          </StackPanel>

          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="14" RowSpacing="8">
            <TextBlock Text="Version" FontWeight="SemiBold" />
            <TextBlock x:Name="VersionTextBlock" Grid.Column="1" />
            <TextBlock Grid.Row="1" Text="OS" FontWeight="SemiBold" />
            <TextBlock x:Name="OsTextBlock" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" />
            <TextBlock Grid.Row="2" Text="Process" FontWeight="SemiBold" />
            <TextBlock x:Name="ProcessTextBlock" Grid.Row="2" Grid.Column="1" />
            <TextBlock Grid.Row="3" Text=".NET" FontWeight="SemiBold" />
            <TextBlock x:Name="DotNetTextBlock" Grid.Row="3" Grid.Column="1" />
            <TextBlock Grid.Row="4" Text="Runtime" FontWeight="SemiBold" />
            <TextBlock x:Name="RuntimeTextBlock" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" />
            <TextBlock Grid.Row="5" Text="License" FontWeight="SemiBold" />
            <TextBlock Grid.Row="5" Grid.Column="1" Text="GPL-3.0-only" />
          </Grid>
        </StackPanel>
      </TabItem>

      <TabItem Header="Links">
        <StackPanel Margin="4,16" Spacing="12">
          <TextBlock Text="Project links" Classes="sectionTitle" />
          <TextBlock Text="Open the project page or the release/download page in your browser." Classes="hint" />
          <Button Content="Project website"
                  Width="190"
                  HorizontalContentAlignment="Center"
                  Click="ProjectButton_Click" />
          <Button Content="Releases / Downloads"
                  Width="190"
                  HorizontalContentAlignment="Center"
                  Click="ReleasesButton_Click" />
        </StackPanel>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
      <Button Classes="dialogAction"
              Content="Close"
              Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
