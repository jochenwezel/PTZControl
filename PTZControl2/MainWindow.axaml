<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PTZControl2.MainWindow"
        Title="PTZControl2"
        Width="980"
        Height="580"
        MinWidth="980"
        MinHeight="580"
        Background="#F4F6F8"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
  <Window.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#D8DEE6" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="Button.preset">
      <Setter Property="Width" Value="76" />
      <Setter Property="Height" Value="76" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#233142" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.motion">
      <Setter Property="Width" Value="76" />
      <Setter Property="Height" Value="76" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="#3B5B7A" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.zoom">
      <Setter Property="Width" Value="76" />
      <Setter Property="Height" Value="76" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="#1E7A68" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#16202A" />
    </Style>
    <Style Selector="TextBlock.icon">
      <Setter Property="FontSize" Value="21" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.miniLabel">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#607080" />
    </Style>
  </Window.Styles>

  <Grid Margin="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
    <Border Classes="panel" Padding="14">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
        <TextBlock Text="Camera"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="#16202A" />
        <ComboBox x:Name="CameraSelector"
                  Grid.Column="1"
                  MinWidth="320"
                  VerticalAlignment="Center"
                  SelectionChanged="CameraSelector_SelectionChanged" />
        <Button Grid.Column="2"
                Content="Info"
                Padding="16,8"
                Click="ShowCameraInfoButton_Click" />
        <Button Grid.Column="3"
                Content="Refresh"
                Padding="16,8"
                Click="RefreshButton_Click" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="16" HorizontalAlignment="Center">
      <Border Classes="panel" Width="500">
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Presets" Classes="sectionTitle" />
            <TextBlock Grid.Column="1"
                       Text="Restore saved camera positions"
                       Foreground="#607080"
                       FontSize="12"
                       VerticalAlignment="Center" />
          </Grid>

          <UniformGrid Grid.Row="1" Columns="4" Rows="3">
            <Button Classes="preset" Tag="1" Click="PresetButton_Click" ToolTip.Tip="Restore preset 1. In memory mode, save the current position to preset 1.">
              <StackPanel Spacing="4">
                <TextBlock Text="1" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset1Text" Text="Preset 1" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="2" Click="PresetButton_Click" ToolTip.Tip="Restore preset 2. In memory mode, save the current position to preset 2.">
              <StackPanel Spacing="4">
                <TextBlock Text="2" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset2Text" Text="Preset 2" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="3" Click="PresetButton_Click" ToolTip.Tip="Restore preset 3. In memory mode, save the current position to preset 3.">
              <StackPanel Spacing="4">
                <TextBlock Text="3" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset3Text" Text="Preset 3" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="4" Click="PresetButton_Click" ToolTip.Tip="Restore preset 4. In memory mode, save the current position to preset 4.">
              <StackPanel Spacing="4">
                <TextBlock Text="4" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset4Text" Text="Preset 4" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="5" Click="PresetButton_Click" ToolTip.Tip="Restore preset 5. In memory mode, save the current position to preset 5.">
              <StackPanel Spacing="4">
                <TextBlock Text="5" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset5Text" Text="Preset 5" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="6" Click="PresetButton_Click" ToolTip.Tip="Restore preset 6. In memory mode, save the current position to preset 6.">
              <StackPanel Spacing="4">
                <TextBlock Text="6" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset6Text" Text="Preset 6" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="7" Click="PresetButton_Click" ToolTip.Tip="Restore preset 7. In memory mode, save the current position to preset 7.">
              <StackPanel Spacing="4">
                <TextBlock Text="7" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset7Text" Text="Preset 7" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Tag="8" Click="PresetButton_Click" ToolTip.Tip="Restore preset 8. In memory mode, save the current position to preset 8.">
              <StackPanel Spacing="4">
                <TextBlock Text="8" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset8Text" Text="Preset 8" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Background="#2E7D66" Click="HomeButton_Click" ToolTip.Tip="Restore the camera home position.">
              <StackPanel Spacing="4">
                <TextBlock Text="⌂" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Home" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Background="#4B647C" Click="DefaultAllButton_Click" ToolTip.Tip="Restore driver default values for zoom, pan, and tilt.">
              <StackPanel Spacing="4">
                <TextBlock Text="↺" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Default" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="MemoryButton" Classes="preset" Background="#735C2C" Click="MemoryButton_Click" ToolTip.Tip="Enable memory mode. The next preset click saves the current camera position. Click again or press Esc to cancel.">
              <StackPanel Spacing="4">
                <TextBlock Text="M" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Memory" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Background="#606B78" Click="SettingsButton_Click" ToolTip.Tip="Open PTZControl2 settings.">
              <StackPanel Spacing="4">
                <TextBlock Text="⚙" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Settings" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
          </UniformGrid>
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="panel" Width="430">
        <StackPanel Spacing="12">
          <TextBlock Text="Live control" Classes="sectionTitle" HorizontalAlignment="Center" />

          <Grid ColumnDefinitions="76,76,76,28,76" RowDefinitions="76,76,76" ColumnSpacing="8" RowSpacing="8" HorizontalAlignment="Center">
            <Button Grid.Column="1" Grid.Row="0" Classes="motion" Click="TiltUpButton_Click" ToolTip.Tip="Tilt up by the selected step size.">
              <StackPanel>
                <TextBlock Text="▲" Classes="icon" />
                <TextBlock Text="Tilt" Classes="caption" />
              </StackPanel>
            </Button>
            <Button Grid.Column="0" Grid.Row="1" Classes="motion" Click="PanLeftButton_Click" ToolTip.Tip="Pan left by the selected step size.">
              <StackPanel>
                <TextBlock Text="◀" Classes="icon" />
                <TextBlock Text="Pan" Classes="caption" />
              </StackPanel>
            </Button>
            <Button Grid.Column="2" Grid.Row="1" Classes="motion" Click="PanRightButton_Click" ToolTip.Tip="Pan right by the selected step size.">
              <StackPanel>
                <TextBlock Text="▶" Classes="icon" />
                <TextBlock Text="Pan" Classes="caption" />
              </StackPanel>
            </Button>
            <Button Grid.Column="1" Grid.Row="2" Classes="motion" Click="TiltDownButton_Click" ToolTip.Tip="Tilt down by the selected step size.">
              <StackPanel>
                <TextBlock Text="▼" Classes="icon" />
                <TextBlock Text="Tilt" Classes="caption" />
              </StackPanel>
            </Button>
            <Button Grid.Column="4" Grid.Row="0" Classes="zoom" Click="ZoomInButton_Click" ToolTip.Tip="Increase zoom by the selected step size.">
              <StackPanel>
                <TextBlock Text="+" Classes="icon" />
                <TextBlock Text="Zoom in" Classes="caption" />
              </StackPanel>
            </Button>
            <Button Grid.Column="4" Grid.Row="2" Classes="zoom" Click="ZoomOutButton_Click" ToolTip.Tip="Decrease zoom by the selected step size.">
              <StackPanel>
                <TextBlock Text="−" Classes="icon" />
                <TextBlock Text="Zoom out" Classes="caption" />
              </StackPanel>
            </Button>
          </Grid>

          <Grid RowDefinitions="Auto,Auto" RowSpacing="4" Margin="0,6,0,0">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Step size" Classes="miniLabel" />
              <TextBlock x:Name="StepValueText"
                         Grid.Column="1"
                         Text="10"
                         FontWeight="SemiBold"
                         Foreground="#16202A" />
            </Grid>
            <Slider x:Name="StepSlider"
                    Grid.Row="1"
                    MinWidth="360"
                    Minimum="1"
                    Maximum="30"
                    TickFrequency="1"
                    IsSnapToTickEnabled="False"
                    Value="10"
                    VerticalAlignment="Center" />
          </Grid>
        </StackPanel>
      </Border>
    </Grid>

    <Border x:Name="StatusBorder"
            Grid.Row="2"
            Background="#E8EDF2"
            BorderBrush="#CED6DF"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,9">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <TextBlock x:Name="StatusText"
                   Text="Ready."
                   Foreground="#263442"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Content="Help"
                Padding="14,4"
                VerticalAlignment="Center"
                Click="HelpButton_Click" />
      </Grid>
    </Border>
  </Grid>
</Window>
