<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PTZControl2.MainWindow"
        Title="PTZControl2"
        Width="980"
        Height="580"
        MinWidth="980"
        MinHeight="580"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">
  <Window.Styles>
    <Style Selector="Border.panel">
      <Setter Property="Background" Value="{DynamicResource AppPanelBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="7" />
    </Style>
    <Style Selector="Button.preset">
      <Setter Property="Width" Value="76" />
      <Setter Property="Height" Value="76" />
      <Setter Property="Margin" Value="4" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="Background" Value="#233142" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.motion">
      <Setter Property="Width" Value="76" />
      <Setter Property="Height" Value="76" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="#3B5B7A" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.zoom">
      <Setter Property="Width" Value="76" />
      <Setter Property="Height" Value="76" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="#1E7A68" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
    </Style>
    <Style Selector="TextBlock.icon">
      <Setter Property="FontSize" Value="21" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.miniLabel">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
    </Style>
    <Style Selector="Button.tabTitle">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0,0,0,4" />
      <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.tabTitle:selected">
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
      <Setter Property="BorderThickness" Value="0,0,0,2" />
      <Setter Property="BorderBrush" Value="#0078D4" />
    </Style>
    <Style Selector="TextBlock.tabTitleText">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
    </Style>
  </Window.Styles>

  <Grid Margin="16" RowDefinitions="Auto,*,Auto" RowSpacing="12">
    <Border Classes="panel" Padding="14">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="10">
        <TextBlock Text="Camera"
                   VerticalAlignment="Center"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextBrush}" />
        <ComboBox x:Name="CameraSelector"
                  Grid.Column="1"
                  MinWidth="320"
                  VerticalAlignment="Center"
                  SelectionChanged="CameraSelector_SelectionChanged" />
        <Button x:Name="PreviewButton"
                Grid.Column="2"
                Content="Preview"
                Padding="16,8"
                Click="PreviewButton_Click" />
        <Button Grid.Column="3"
                Content="Info"
                Padding="16,8"
                Click="ShowCameraInfoButton_Click" />
        <Button Grid.Column="4"
                Content="Refresh"
                Padding="16,8"
                Click="RefreshButton_Click" />
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto" ColumnSpacing="16" HorizontalAlignment="Center">
      <Border Classes="panel" Width="500">
        <Grid RowDefinitions="Auto,*" RowSpacing="12">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Presets" Classes="sectionTitle" />
            <TextBlock Grid.Column="1"
                       Text="Restore saved camera positions"
                       Foreground="{DynamicResource AppMutedTextBrush}"
                       FontSize="12"
                       VerticalAlignment="Center" />
          </Grid>

          <UniformGrid Grid.Row="1" Columns="4" Rows="3">
            <Button x:Name="Preset1Button" Classes="preset" Tag="1" Click="PresetButton_Click" ToolTip.Tip="Restore preset 1. In memory mode, save the current position to preset 1.">
              <StackPanel Spacing="4">
                <TextBlock Text="1" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset1Text" Text="Preset 1" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset2Button" Classes="preset" Tag="2" Click="PresetButton_Click" ToolTip.Tip="Restore preset 2. In memory mode, save the current position to preset 2.">
              <StackPanel Spacing="4">
                <TextBlock Text="2" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset2Text" Text="Preset 2" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset3Button" Classes="preset" Tag="3" Click="PresetButton_Click" ToolTip.Tip="Restore preset 3. In memory mode, save the current position to preset 3.">
              <StackPanel Spacing="4">
                <TextBlock Text="3" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset3Text" Text="Preset 3" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset4Button" Classes="preset" Tag="4" Click="PresetButton_Click" ToolTip.Tip="Restore preset 4. In memory mode, save the current position to preset 4.">
              <StackPanel Spacing="4">
                <TextBlock Text="4" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset4Text" Text="Preset 4" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset5Button" Classes="preset" Tag="5" Click="PresetButton_Click" ToolTip.Tip="Restore preset 5. In memory mode, save the current position to preset 5.">
              <StackPanel Spacing="4">
                <TextBlock Text="5" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset5Text" Text="Preset 5" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset6Button" Classes="preset" Tag="6" Click="PresetButton_Click" ToolTip.Tip="Restore preset 6. In memory mode, save the current position to preset 6.">
              <StackPanel Spacing="4">
                <TextBlock Text="6" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset6Text" Text="Preset 6" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset7Button" Classes="preset" Tag="7" Click="PresetButton_Click" ToolTip.Tip="Restore preset 7. In memory mode, save the current position to preset 7.">
              <StackPanel Spacing="4">
                <TextBlock Text="7" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset7Text" Text="Preset 7" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="Preset8Button" Classes="preset" Tag="8" Click="PresetButton_Click" ToolTip.Tip="Restore preset 8. In memory mode, save the current position to preset 8.">
              <StackPanel Spacing="4">
                <TextBlock Text="8" FontSize="22" FontWeight="SemiBold" />
                <TextBlock x:Name="Preset8Text" Text="Preset 8" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="HomeButton" Classes="preset" Background="#2E7D66" Click="HomeButton_Click" ToolTip.Tip="Restore the camera home position.">
              <StackPanel Spacing="4">
                <TextBlock Text="⌂" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Home" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="DefaultAllButton" Classes="preset" Background="#4B647C" Click="DefaultAllButton_Click" ToolTip.Tip="Restore driver default values for zoom, pan, and tilt.">
              <StackPanel Spacing="4">
                <TextBlock Text="↺" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Default" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button x:Name="MemoryButton" Classes="preset" Background="#735C2C" Click="MemoryButton_Click" ToolTip.Tip="Enable memory mode. The next preset click saves the current camera position. Click again or press Esc to cancel.">
              <StackPanel Spacing="4">
                <TextBlock Text="M" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Memory" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
            <Button Classes="preset" Background="#606B78" Click="SettingsButton_Click" ToolTip.Tip="Open PTZControl2 settings.">
              <StackPanel Spacing="4">
                <TextBlock Text="⚙" FontSize="22" FontWeight="SemiBold" />
                <TextBlock Text="Settings" TextWrapping="Wrap" FontSize="13" />
              </StackPanel>
            </Button>
          </UniformGrid>
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="panel" Width="430">
        <Grid RowDefinitions="Auto,*" RowSpacing="8">
          <StackPanel Orientation="Horizontal" Spacing="22">
            <Button x:Name="MoveZoomTabButton"
                    Classes="tabTitle selected"
                    Click="MoveZoomTabButton_Click">
              <TextBlock Text="Move/Zoom" Classes="tabTitleText" />
            </Button>
            <Button x:Name="PictureTabButton"
                    Classes="tabTitle"
                    Click="PictureTabButton_Click">
              <TextBlock Text="Picture" Classes="tabTitleText" />
            </Button>
          </StackPanel>
          <Grid Grid.Row="1">
            <StackPanel x:Name="MoveZoomTabPanel" Spacing="9" Margin="0,4,0,0">
              <Grid ColumnDefinitions="76,76,76,28,76" RowDefinitions="76,76,76" ColumnSpacing="8" RowSpacing="8" HorizontalAlignment="Center">
                <Button x:Name="TiltUpButton" Grid.Column="1" Grid.Row="0" Classes="motion" Click="TiltUpButton_Click" ToolTip.Tip="Tilt up by the selected step size.">
                  <StackPanel>
                    <TextBlock Text="▲" Classes="icon" />
                    <TextBlock Text="Tilt" Classes="caption" />
                  </StackPanel>
                </Button>
                <Button x:Name="PanLeftButton" Grid.Column="0" Grid.Row="1" Classes="motion" Click="PanLeftButton_Click" ToolTip.Tip="Pan left by the selected step size.">
                  <StackPanel>
                    <TextBlock Text="◀" Classes="icon" />
                    <TextBlock Text="Pan" Classes="caption" />
                  </StackPanel>
                </Button>
                <Button x:Name="PanRightButton" Grid.Column="2" Grid.Row="1" Classes="motion" Click="PanRightButton_Click" ToolTip.Tip="Pan right by the selected step size.">
                  <StackPanel>
                    <TextBlock Text="▶" Classes="icon" />
                    <TextBlock Text="Pan" Classes="caption" />
                  </StackPanel>
                </Button>
                <Button x:Name="TiltDownButton" Grid.Column="1" Grid.Row="2" Classes="motion" Click="TiltDownButton_Click" ToolTip.Tip="Tilt down by the selected step size.">
                  <StackPanel>
                    <TextBlock Text="▼" Classes="icon" />
                    <TextBlock Text="Tilt" Classes="caption" />
                  </StackPanel>
                </Button>
                <Button x:Name="ZoomInButton" Grid.Column="4" Grid.Row="0" Classes="zoom" Click="ZoomInButton_Click" ToolTip.Tip="Increase zoom by the selected step size.">
                  <StackPanel>
                    <TextBlock Text="+" Classes="icon" />
                    <TextBlock Text="Zoom in" Classes="caption" />
                  </StackPanel>
                </Button>
                <Button x:Name="ZoomOutButton" Grid.Column="4" Grid.Row="2" Classes="zoom" Click="ZoomOutButton_Click" ToolTip.Tip="Decrease zoom by the selected step size.">
                  <StackPanel>
                    <TextBlock Text="−" Classes="icon" />
                    <TextBlock Text="Zoom out" Classes="caption" />
                  </StackPanel>
                </Button>
              </Grid>

              <Grid RowDefinitions="Auto,Auto" RowSpacing="2" Margin="0,0,0,0">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Step size" Classes="miniLabel" />
                  <TextBlock x:Name="StepValueText"
                             Grid.Column="1"
                             Text="10"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource AppTextBrush}" />
                </Grid>
                <Slider x:Name="StepSlider"
                        Grid.Row="1"
                        MinWidth="360"
                        Minimum="1"
                        Maximum="30"
                        TickFrequency="1"
                        IsSnapToTickEnabled="False"
                        Value="10"
                        VerticalAlignment="Center" />
              </Grid>
            </StackPanel>
            <StackPanel x:Name="PictureTabPanel" IsVisible="False" Margin="0,8,0,0" Spacing="10">
              <Grid ColumnDefinitions="78,*,42" ColumnSpacing="8">
                <TextBlock Text="Brightness" Classes="miniLabel" VerticalAlignment="Center" />
                <Slider x:Name="BrightnessSlider" Grid.Column="1" PropertyChanged="PictureSlider_PropertyChanged" />
                <TextBlock x:Name="BrightnessValueText" Grid.Column="2" Classes="miniLabel" TextAlignment="Right" VerticalAlignment="Center" />
              </Grid>
              <Grid ColumnDefinitions="78,*,42" ColumnSpacing="8">
                <TextBlock Text="Contrast" Classes="miniLabel" VerticalAlignment="Center" />
                <Slider x:Name="ContrastSlider" Grid.Column="1" PropertyChanged="PictureSlider_PropertyChanged" />
                <TextBlock x:Name="ContrastValueText" Grid.Column="2" Classes="miniLabel" TextAlignment="Right" VerticalAlignment="Center" />
              </Grid>
              <Grid ColumnDefinitions="78,*,42" ColumnSpacing="8">
                <TextBlock Text="Sharpness" Classes="miniLabel" VerticalAlignment="Center" />
                <Slider x:Name="SharpnessSlider" Grid.Column="1" PropertyChanged="PictureSlider_PropertyChanged" />
                <TextBlock x:Name="SharpnessValueText" Grid.Column="2" Classes="miniLabel" TextAlignment="Right" VerticalAlignment="Center" />
              </Grid>
              <Grid ColumnDefinitions="78,*,42" ColumnSpacing="8">
                <TextBlock Text="Saturation" Classes="miniLabel" VerticalAlignment="Center" />
                <Slider x:Name="SaturationSlider" Grid.Column="1" PropertyChanged="PictureSlider_PropertyChanged" />
                <TextBlock x:Name="SaturationValueText" Grid.Column="2" Classes="miniLabel" TextAlignment="Right" VerticalAlignment="Center" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,4,0,0">
                <TextBlock x:Name="PictureStatusText"
                           Classes="miniLabel"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Reset"
                        Padding="12,4"
                        Click="ResetPictureDefaultsButton_Click" />
              </Grid>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <Border x:Name="StatusBorder"
            Grid.Row="2"
            Background="{DynamicResource AppStatusBrush}"
            BorderBrush="{DynamicResource AppStatusBorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12,9">
      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
        <TextBlock x:Name="StatusText"
                   Text="Ready."
                   Foreground="{DynamicResource AppTextBrush}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                Content="Help"
                Padding="14,4"
                VerticalAlignment="Center"
                Click="HelpButton_Click" />
        <Button Grid.Column="2"
                Content="About"
                Padding="14,4"
                VerticalAlignment="Center"
                Click="AboutButton_Click" />
      </Grid>
    </Border>
  </Grid>
</Window>
